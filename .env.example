# ── BSC RPC ──────────────────────────────────────────────────────────
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# Alchemy RPC (server-side, primary + backups)
BSC_ALCHEMY_RPC_URL=https://bnb-mainnet.g.alchemy.com/v2/YOUR_KEY
BSC_ALCHEMY_RPC_URL2=https://bnb-mainnet.g.alchemy.com/v2/YOUR_KEY_2
BSC_ALCHEMY_RPC_URL3=https://bnb-mainnet.g.alchemy.com/v2/YOUR_KEY_3
BSC_ALCHEMY_RPC_URL4=https://bnb-mainnet.g.alchemy.com/v2/YOUR_KEY_4
BSC_ALCHEMY_RPC_URL5=https://bnb-mainnet.g.alchemy.com/v2/YOUR_KEY_5

# Alchemy public keys (exposed to browser)
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key
NEXT_PUBLIC_ALCHEMY_API_KEY2=your_alchemy_api_key_2
NEXT_PUBLIC_ALCHEMY_API_KEY3=your_alchemy_api_key_3
NEXT_PUBLIC_ALCHEMY_API_KEY4=your_alchemy_api_key_4

# ── Deployer / Verification ─────────────────────────────────────────
# NEVER commit your real private key!
DEPLOYER_PRIVATE_KEY=your_private_key_here
BSCSCAN_API_KEY=your_bscscan_api_key_here

# ── Privy ────────────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# ── Staking Contract ────────────────────────────────────────────────
# Deploy RWANSecureStakingV4 first, then paste the address here.
NEXT_PUBLIC_RWAN_V4_STAKING_ADDRESS=0x0000000000000000000000000000000000000000

# ── Supabase (referral system + leaderboard) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Leaderboard Indexer ─────────────────────────────────────────────
# RPC the indexer uses (falls back to BSC_TESTNET_RPC_URL if unset)
LEADERBOARD_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
# Contract address the indexer watches (server-side, no NEXT_PUBLIC_ prefix)
RWAN_V4_STAKING_ADDRESS=0x0000000000000000000000000000000000000000
# Block number the contract was deployed at (indexer starts scanning here)
RWAN_V4_DEPLOY_BLOCK=0

# ── Email (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here

# ── Admin Preview ───────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_PREVIEW=false
